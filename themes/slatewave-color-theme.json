  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#64748b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#e2e8f0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters variable"
      ],
      "settings": {
        "foreground": "#cbd5e1",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties / object keys",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#cbd5e1"
      }
    },
    {
      "name": "Built-in / language variables (this, self, super)",
      "scope": [
        "variable.language",
        "variable.other.readwrite.instance"
      ],
      "settings": {
        "foreground": "#B388FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant",
        "constant.other.caps"
      ],
      "settings": {
        "foreground": "#fb7185"
      }
    },
    {
      "name": "Numbers / booleans / null",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan",
        "constant.language.infinity"
      ],
      "settings": {
        "foreground": "#fb7185"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape",
        "constant.character.entity"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#5eead4"
      }
    },
    {
      "name": "Template string punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#B388FF"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#fb7185"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.operator.word"
      ],
      "settings": {
        "foreground": "#38bdf8"
      }
    },
    {
      "name": "Storage (let/const/var/function/class/interface)",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#B388FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Types / classes / interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "support.type",
        "support.class",
        "meta.type.declaration entity.name.type"
      ],
      "settings": {
        "foreground": "#99f6e4"
      }
    },
    {
      "name": "Primitive types (string, number, boolean)",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "keyword.type"
      ],
      "settings": {
        "foreground": "#38bdf8"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function",
        "meta.require",
        "variable.function"
      ],
      "settings": {
        "foreground": "#7dd3fc"
      }
    },
    {
      "name": "Function method calls",
      "scope": [
        "meta.method-call entity.name.function",
        "meta.function-call.method"
      ],
      "settings": {
        "foreground": "#7dd3fc"
      }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator",
        "tag.decorator"
      ],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.bitwise",
        "keyword.operator.accessor"
      ],
      "settings": {
        "foreground": "#94a3b8"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#94a3b8"
      }
    },
    {
      "name": "Invalid / illegal",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ef5350",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Invalid deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#b45309",
        "fontStyle": "italic"
      }
    },

    {
      "name": "HTML/JSX/XML tags",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#38bdf8"
      }
    },
    {
      "name": "HTML/JSX attribute names",
      "scope": [
        "entity.other.attribute-name",
        "meta.attribute"
      ],
      "settings": {
        "foreground": "#B388FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Tag punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#64748b"
      }
    },

    {
      "name": "CSS selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#5eead4"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#7dd3fc"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#e2e8f0"
      }
    },
    {
      "name": "CSS pseudo selectors",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "name": "CSS variables / custom properties",
      "scope": [
        "variable.css",
        "variable.other.custom-property.css"
      ],
      "settings": {
        "foreground": "#B388FF"
      }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit.css",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#94a3b8"
      }
    },

    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#5eead4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "foreground": "#38bdf8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "foreground": "#B388FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.inline.raw",
        "markup.raw.inline",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#99f6e4"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#38bdf8",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown link text",
      "scope": [
        "meta.link.inline.markdown string.other.link",
        "entity.name.reference.link.markdown"
      ],
      "settings": {
        "foreground": "#5eead4"
      }
    },
    {
      "name": "Markdown lists",
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin"
      ],
      "settings": {
        "foreground": "#fb7185"
      }
    },
    {
      "name": "Markdown quotes",
      "scope": [
        "markup.quote",
        "punctuation.definition.quote"
      ],
      "settings": {
        "foreground": "#94a3b8",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#5eead4"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#fb7185"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "name": "Diff header",
      "scope": [
        "meta.diff.header",
        "meta.diff.range"
      ],
      "settings": {
        "foreground": "#B388FF"
      }
    },

    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json",
        "meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#7dd3fc"
      }
    },
    {
      "name": "YAML keys",
      "scope": [
        "entity.name.tag.yaml",
        "string.unquoted.plain.out.yaml"
      ],
      "settings": {
        "foreground": "#7dd3fc"
      }
    },

    {
      "name": "Shell built-in commands",
      "scope": [
        "support.function.builtin.shell",
        "variable.parameter.posix-reserved.shell"
      ],
      "settings": {
        "foreground": "#38bdf8"
      }
    },
    {
      "name": "Shell variables",
      "scope": [
        "variable.other.normal.shell",
        "variable.other.positional.shell"
      ],
      "settings": {
        "foreground": "#B388FF"
      }
    },

    {
      "name": "Git commit message keywords",
      "scope": [
        "text.git-commit",
        "meta.scope.message.git-commit"
      ],
      "settings": {
        "foreground": "#e2e8f0"
      }
    },

    {
      "name": "URL links",
      "scope": [
        "string.other.link",
        "markup.underline"
      ],
      "settings": {
        "foreground": "#38bdf8"
      }
    },

    {
      "name": "Go package name",
      "scope": [
        "entity.name.package.go"
      ],
      "settings": {
        "foreground": "#5eead4"
      }
    },
    {
      "name": "Go import path",
      "scope": [
        "string.quoted.double.go"
      ],
      "settings": {
        "foreground": "#5eead4"
      }
    },
    {
      "name": "Go struct tags",
      "scope": [
        "string.quoted.raw.go"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },

    {
      "name": "Python self / cls",
      "scope": [
        "variable.language.special.self.python",
        "variable.language.special.cls.python"
      ],
      "settings": {
        "foreground": "#B388FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python decorators",
      "scope": [
        "meta.function.decorator.python",
        "entity.name.function.decorator.python"
      ],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "italic"
      }
    },

    {
      "name": "TS/JS this / super",
      "scope": [
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#B388FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSX braces",
      "scope": [
        "punctuation.section.embedded.begin.jsx",
        "punctuation.section.embedded.end.jsx",
        "punctuation.section.embedded.begin.tsx",
        "punctuation.section.embedded.end.tsx"
      ],
      "settings": {
        "foreground": "#B388FF"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#5eead4",
    "class": "#99f6e4",
    "interface": "#99f6e4",
    "type": "#99f6e4",
    "enum": "#99f6e4",
    "enumMember": "#fb7185",
    "typeParameter": "#99f6e4",
    "function": "#7dd3fc",
    "method": "#7dd3fc",
    "macro": "#fbbf24",
    "variable": "#e2e8f0",
    "parameter": {
      "foreground": "#cbd5e1",
      "fontStyle": "italic"
    },
    "property": "#cbd5e1",
    "enumMember.readonly": "#fb7185",
    "variable.readonly": "#fb7185",
    "variable.defaultLibrary": "#B388FF",
    "function.defaultLibrary": "#38bdf8",
    "keyword": "#38bdf8",
    "modifier": "#B388FF",
    "operator": "#94a3b8",
    "string": "#5eead4",
    "number": "#fb7185",
    "comment": {
      "foreground": "#64748b",
      "fontStyle": "italic"
    },
    "decorator": "#fbbf24",
    "*.declaration": {
      "fontStyle": "bold"
    },
    "*.deprecated": {
      "fontStyle": "strikethrough"
    }
  }
}
